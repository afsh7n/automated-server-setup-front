# Dockerfile for Onomis Docs Project
FROM node:16-alpine

WORKDIR /usr/src/app

# Install dependencies and serve globally
COPY ./../src/onomis-docs/package*.json ./
RUN npm install
RUN npm install -g serve

# Copy application source code
COPY ./../src/onomis-docs/. ./

# Build the Docs project
RUN npm run docs:build

# Expose port and start the server
EXPOSE 3001
CMD ["serve", "-s", ".vitepress/dist"]
